{
  "name": "@marketplace/logger",
  "version": "1.0.0",
  "description": "Centralized logging package for marketplace platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "10.1.0",
    "pino-pretty": "13.1.2"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
