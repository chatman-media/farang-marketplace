{
  "name": "@marketplace/logger",
  "version": "1.0.0",
  "description": "Centralized logging package for marketplace platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "pino": "10.1.0",
    "pino-pretty": "13.1.2"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
