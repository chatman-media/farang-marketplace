# Database Configuration for Schema Migrations
# Copy this file to .env and update with your database credentials

# Development Database
DATABASE_URL=postgresql://marketplace_user:marketplace_pass@localhost:5432/marketplace

# Test Database (used during testing)
TEST_DATABASE_URL=postgresql://marketplace_user:marketplace_pass@localhost:5432/marketplace_test

# Production Database (set in production environment)
# DATABASE_URL=your_production_database_url
