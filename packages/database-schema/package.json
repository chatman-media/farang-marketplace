{
  "name": "@marketplace/database-schema",
  "version": "1.0.0",
  "description": "Shared database schema for Thailand Marketplace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@marketplace/shared-types": "^1.0.0",
    "@marketplace/logger": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "drizzle-kit": "^0.31.6",
    "typescript": "^5.9.3",
    "vitest": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "dotenv": "17.4.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./connection": {
      "types": "./dist/connection.d.ts",
      "default": "./dist/connection.js"
    },
    "./shared-db": {
      "types": "./dist/shared-db.d.ts",
      "default": "./dist/shared-db.js"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "default": "./dist/migrations.js"
    }
  }
}
