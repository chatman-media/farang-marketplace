# Database Configuration
DATABASE_URL=postgresql://marketplace_user:marketplace_pass@localhost:5432/marketplace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketplace
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=marketplace_pass

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Vercel Blob Storage Configuration
# Get your token at: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Alternative: MinIO/S3 for local development (optional)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET_IMAGES=marketplace-images
# MINIO_BUCKET_DOCUMENTS=marketplace-documents

# Email Configuration (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@marketplace.local

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# API Configuration (modular monolith — one app, one port)
PORT=3000
API_HOST=localhost
API_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
UPLOAD_PATH=uploads
RATE_LIMIT_MAX=1000

# Worker process
# RUN_WORKERS_INLINE=1   # start background workers inside the API process (single-box dev)

# Payments
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# AI search (optional — listing AI degrades to fallbacks when unset)
# AI_SERVICE_URL=http://localhost:3006

# External Services
TON_NETWORK=testnet
TON_API_KEY=your-ton-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# Development
NODE_ENV=development
LOG_LEVEL=debug
ENABLE_CORS=true

# Monitoring
SENTRY_DSN=your-sentry-dsn