{
  "name": "@marketplace/web",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "dev:client": "vite",
    "build": "vite build && vite build --ssr src/entry-server.tsx",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx",
    "preview": "node server.js",
    "serve": "node server.js",
    "test": "vitest run --no-coverage --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@marketplace/logger": "*",
    "@marketplace/shared-types": "*",
    "@remix-run/node": "^2.17.5",
    "@remix-run/serve": "^2.17.5",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-query-devtools": "^5.90.2",
    "axios": "^1.16.0",
    "fastify": "^5.8.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/node": "^25.9.4",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "undici": "^8.5.0",
    "vite": "7.3.5",
    "vitest": "4.1.9",
    "@testing-library/dom": "^10.4.1"
  }
}
