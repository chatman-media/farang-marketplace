{
  "name": "@thailand-marketplace/agency-service",
  "version": "1.0.0",
  "description": "Agency management service for Thailand Marketplace platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "agency",
    "service",
    "marketplace",
    "thailand",
    "commission",
    "management"
  ],
  "author": "Thailand Marketplace Team",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@marketplace/shared-types": "workspace:*",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "bcryptjs": "3.0.3",
    "dotenv": "17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "2.0.2",
    "sharp": "^0.34.4",
    "uuid": "13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "25.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/bcryptjs": "3.0.0",
    "@types/uuid": "11.0.0",
    "@types/multer": "2.0.0",
    "drizzle-kit": "^0.31.6",
    "typescript": "^5.9.3",
    "vitest": "4.0.7",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4"
  }
}
