{
  "name": "@marketplace/booking-service",
  "version": "1.0.0",
  "description": "Booking and transaction management service for Thailand Marketplace",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/listing-service": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "@marketplace/shared-types": "workspace:*",
    "bcryptjs": "3.0.3",
    "dotenv": "17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "4.2.1",
    "redis": "5.9.0",
    "uuid": "13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "24.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "11.0.0",
    "@vitest/coverage-v8": "4.0.7",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "4.0.7"
  },
  "keywords": [
    "marketplace",
    "booking",
    "thailand",
    "rental",
    "transactions",
    "payments"
  ],
  "author": "Thailand Marketplace Team",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./src/routes/index.ts",
      "default": "./dist/routes/index.js"
    }
  }
}
