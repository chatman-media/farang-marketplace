{
  "name": "@marketplace/payment-service",
  "version": "1.0.0",
  "description": "Payment processing service with TON blockchain integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "payment",
    "blockchain",
    "ton",
    "marketplace",
    "typescript",
    "fastify"
  ],
  "author": "Thailand Marketplace",
  "license": "MIT",
  "dependencies": {
    "@marketplace/shared-types": "workspace:*",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "@tonconnect/sdk": "^3.3.1",
    "axios": "^1.16.0",
    "bullmq": "^5.63.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "17.4.2",
    "fastify": "^5.8.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "stripe": "19.2.0",
    "ton": "^13.9.0",
    "ton-core": "^0.53.0",
    "ton-crypto": "^3.2.0",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.4",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "11.0.0",
    "drizzle-kit": "^0.31.6",
    "supertest": "^7.2.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./src/routes/index.ts",
      "default": "./dist/routes/index.js"
    },
    "./jobs": {
      "types": "./src/jobs/index.ts",
      "default": "./dist/jobs/index.js"
    }
  }
}
