{
  "name": "@thailand-marketplace/api-gateway",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "11.1.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/http-proxy": "11.3.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.1.0",
    "@logtape/logtape": "^1.1.2",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "@marketplace/shared-types": "workspace:*",
    "consul": "2.0.1",
    "dotenv": "17.2.3",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/consul": "2.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "4.0.15"
  }
}
