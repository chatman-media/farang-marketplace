{
  "name": "@marketplace/listing-service",
  "version": "1.0.0",
  "description": "Listing management service for Thailand Marketplace",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@marketplace/shared-types": "workspace:*",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "axios": "^1.16.0",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "drizzle-kit": "^0.31.6",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "node-cron": "4.2.1",
    "pg": "^8.16.3",
    "redis": "6.0.0",
    "sharp": "^0.35.1",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.15.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/bcryptjs": "3.0.0",
    "@types/uuid": "11.0.0",
    "@types/node": "25.9.4",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.9.3",
    "vitest": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "supertest": "7.2.2",
    "@types/supertest": "^6.0.3"
  },
  "keywords": [
    "marketplace",
    "listing",
    "thailand",
    "rental",
    "vehicles",
    "products"
  ],
  "author": "Thailand Marketplace Team",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./src/routes/index.ts",
      "default": "./dist/routes/index.js"
    },
    "./pricing": {
      "types": "./src/pricing/index.ts",
      "default": "./dist/pricing/index.js"
    }
  }
}
