# CI uses test_db with postgres user, locally use marketplace database
# This is overridden in CI by the workflow
# CI will override this with: postgresql://postgres:postgres@localhost:5432/test_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
NODE_ENV=test
JWT_SECRET=test-secret-key
PORT=3007

# Redis Configuration (for caching and session management)
REDIS_URL=redis://localhost:6379/5
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=5

# API Keys for testing (mock values)
LINE_CHANNEL_ACCESS_TOKEN=test-line-channel-access-token
LINE_CHANNEL_SECRET=test-line-channel-secret
TELEGRAM_BOT_TOKEN=test-telegram-bot-token
WHATSAPP_API_KEY=test-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=test-whatsapp-phone-number-id
WHATSAPP_SESSION_PATH=./whatsapp-session-test
OPENAI_API_KEY=test-openai-api-key
SENDGRID_API_KEY=test-sendgrid-api-key
EMAIL_FROM=test@example.com
SMTP_FROM=test@test.com
