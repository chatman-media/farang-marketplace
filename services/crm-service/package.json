{
  "name": "@marketplace/crm-service",
  "version": "1.0.0",
  "description": "CRM and multi-channel communication service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "server": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.4.0",
    "@marketplace/shared-types": "workspace:*",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "@fastify/cors": "11.1.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "^9.3.0",
    "dotenv": "17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "8.0.5",
    "pg": "^8.16.3",
    "redis": "5.9.0",
    "telegraf": "^4.16.3",
    "whatsapp-web.js": "^1.34.1",
    "handlebars": "^4.7.8",
    "bull": "^4.16.5",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "7.0.3",
    "@types/pg": "^8.15.6",
    "@types/handlebars": "^4.1.0",
    "@types/bull": "^4.10.4",
    "@types/cors": "^2.8.19",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "4.1.7",
    "drizzle-kit": "^0.31.6",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "vitest": "4.1.7",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./src/routes/index.ts",
      "default": "./dist/routes/index.js"
    },
    "./cron": {
      "types": "./src/services/CronService.ts",
      "default": "./dist/services/CronService.js"
    }
  }
}
