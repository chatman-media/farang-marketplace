    "@marketplace/logger": "workspace:*",
    "@marketplace/shared-types": "workspace:*",
    "bcryptjs": "3.0.3",
    "dotenv": "17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "redis": "5.9.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^6.0.3",
