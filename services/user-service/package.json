{
  "name": "@marketplace/user-service",
  "version": "1.0.0",
  "description": "User management service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "^9.3.0",
    "@marketplace/database-schema": "workspace:*",
    "@marketplace/logger": "workspace:*",
    "@marketplace/shared-types": "workspace:*",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "redis": "6.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "4.1.9"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./src/routes/index.ts",
      "default": "./dist/routes/index.js"
    }
  }
}
