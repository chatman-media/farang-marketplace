{
  "name": "@marketplace/user-service",
  "version": "1.0.0",
  "description": "User management service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "biome check src/",
