{
  "name": "marketplace-rental-platform",
  "version": "1.0.0",
  "description": "Marketplace for vehicle and equipment rental/sales",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:ui": "turbo run dev --ui=tui",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:all": "./scripts/test-all.sh",
    "test:summary": "./scripts/test-all.sh",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:merge": "./scripts/merge-coverage.sh",
    "test:coverage:upload": "codecov",
    "test:coverage:report": "./scripts/coverage-report.sh",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "biome format .",
    "format:prettier": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:prettier:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "organize-imports": "biome check --write --unsafe .",
    "organize-imports:check": "biome check .",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "setup": "bun install && bun run docker:up && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.3",
    "@eslint/js": "^9.39.0",
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "8.46.3",
    "@typescript-eslint/parser": "8.46.3",
    "@vitejs/plugin-react": "^5.1.0",
    "c8": "^10.1.3",
    "codecov": "^3.8.3",
    "eslint": "9.39.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "nyc": "^17.1.0",
    "prettier": "^3.6.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "turbo": "2.6.0",
    "typescript": "^5.9.3",
    "vite": "7.1.12"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.1",
  "overrides": {
    "drizzle-orm": "0.44.7"
  }
}
