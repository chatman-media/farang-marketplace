{
  "name": "marketplace-rental-platform",
  "version": "1.0.0",
  "description": "Marketplace for vehicle and equipment rental/sales",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@marketplace/api",
    "dev:ui": "turbo run dev --ui=tui --filter=@marketplace/api",
    "worker": "turbo run worker --filter=@marketplace/api",
    "start": "turbo run build --filter=@marketplace/api && bun run --filter @marketplace/api start",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:all": "./scripts/test-all.sh",
    "test:summary": "./scripts/test-all.sh",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:merge": "./scripts/merge-coverage.sh",
    "test:coverage:upload": "codecov",
    "test:coverage:report": "./scripts/coverage-report.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "turbo run type-check",
    "fix:all": "bun run format && bun run lint:fix && bun run type-check",
    "check:all": "bun run format:check && bun run lint && bun run type-check",
    "clean": "turbo run clean",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "setup": "bun install && bun run docker:up && bun run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@codecov/vite-plugin": "^2.0.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "c8": "^11.0.0",
    "codecov": "^3.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nyc": "^18.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "turbo": "2.9.14",
    "typescript": "^6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.1",
  "overrides": {
    "drizzle-orm": "0.44.7",
    "handlebars": "^4.7.9",
    "nodemailer": "^7.0.11",
    "multer": "^2.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --unsafe --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{json,md,yml,yaml}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
